import pandas as pd
from nba_api.stats.static import players
from nba_api.stats.endpoints import playergamelog

# Step 4 & 5: Fetch Games directly from official NBA Database
def get_game_log_api(player_name):
    # Find the player's official league ID by their name
    search_results = players.find_players_by_full_name(player_name)
    if not search_results:
        return pd.DataFrame()
        
    player_id = search_results[0]['id']
    
    # Query the official NBA game log for the current season
    # Note: '2025' pulls the 2025-2026 season statistics
    try:
        gamelog = playergamelog.PlayerGameLog(player_id=player_id, season='2025')
        df = gamelog.get_data_frames()[0]
        return df
    except Exception:
        return pd.DataFrame()

# Step 6: Define the Powerhouse Teams (NBA API uses 3-letter city abbreviations)
ELITE_TEAMS = ['BOS', 'OKC', 'NYK', 'DEN', 'MIN', 'MIL', 'CLE', 'DAL']

# Step 7: Sort the Games into Two Buckets
def split_games(data_frame):
    if data_frame.empty:
        return pd.DataFrame(), pd.DataFrame()
        
    data_frame = data_frame.copy()
    
    # Extract the opposing team from the MATCHUP string (e.g., "LAL @ BOS" or "BOS vs. LAL")
    # This splits the string and grabs the last 3 characters representing the opponent
    data_frame['Opponent'] = data_frame['MATCHUP'].apply(lambda x: x.split(' ')[-1])
    
    # Ensure points are integers
    data_frame['PTS'] = pd.to_numeric(data_frame['PTS'], errors='coerce')
    
    elite_games = data_frame[data_frame['Opponent'].isin(ELITE_TEAMS)]
    regular_games = data_frame[~data_frame['Opponent'].isin(ELITE_TEAMS)]
    return elite_games, regular_games

# Step 8 & 9: Create the Main Calculation Function
def calculate_luna(player_name):
    games_df = get_game_log_api(player_name)
    if games_df.empty:
        return None, None, f"Could not find or fetch official stats for '{player_name}'."
        
    elite_df, regular_df = split_games(games_df)
    
    regular_ppg = regular_df['PTS'].mean() if not regular_df.empty else 0
    elite_ppg = elite_df['PTS'].mean() if not elite_df.empty else 0
    
    luna_score = elite_ppg - regular_ppg
    return regular_ppg, elite_ppg, luna_score

# Step 10: Run the Engine
if __name__ == "__main__":
    print("="*40)
    print("    OFFICIAL NBA LUNA METRIC ENGINE     ")
    print("="*40)
    
    name_input = input("Enter an NBA Player's Name: ")
    print(f"\nPulling official league data for {name_input}... Please wait...")
    
    reg, elite, luna = calculate_luna(name_input)
    
    if isinstance(luna, str):
        print(f"\nError: {luna}")
    else:
        print("\n" + "-"*40)
        print(f" REAL-TIME RESULTS FOR {name_input.upper()}")
        print("-"*40)
        print(f" Regular Teams PPG: {reg:.2f}")
        print(f" Elite Teams PPG:   {elite:.2f}")
        print(f" LUNA Score:        {luna:+0.2f}")
        print("="*40)
